{
  "name": "trip-trace",
  "version": "0.1.0",
  "description": "旅迹 · TripTrace - 旅行照片智能归档工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "dev:renderer": "vite",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package": "electron-builder",
    "preview": "vite preview"
  },
  "keywords": ["photo", "organizer", "travel", "electron"],
  "author": "vera-hlh",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.395.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.vera-hlh.trip-trace",
    "productName": "TripTrace",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "extraResources": [
      {
        "from": "../backend/dist/trip-trace-backend.exe",
        "to": "backend/trip-trace-backend.exe"
      }
    ]
  }
}
